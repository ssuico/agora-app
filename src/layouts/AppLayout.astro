---
import { Sidebar } from '../components/app/Sidebar';
import { Topbar } from '../components/app/Topbar';
import { Toaster } from '../components/app/Toaster';
import { decodeJWT } from '../lib/jwt';
import { createApiClient } from '../lib/api';
import '../styles/global.css';

interface Props {
  title?: string;
  storeId?: string;
}
const { title = 'Agora POS', storeId } = Astro.props;

const token = Astro.cookies.get('agora_token')?.value ?? '';
const payload = decodeJWT(token);
let userName = payload?.name ?? 'User';
let userRole = payload?.role ?? 'customer';
let userAvatar: string | undefined;
try {
  const api = createApiClient(token);
  const me = await api.get<{ name?: string; role?: string; avatar?: string }>('/api/auth/me');
  if (me?.name) userName = me.name;
  if (me?.role) userRole = me.role;
  if (me?.avatar != null) userAvatar = typeof me.avatar === 'string' ? me.avatar : undefined;
} catch {
  // Use JWT payload only
}
const currentPath = Astro.url.pathname;

let storeName: string | undefined;
let storeLocation: string | undefined;
let assignedStores: { _id: string; name: string; locationName?: string }[] = [];

if (storeId) {
  try {
    const api = createApiClient(token);
    const store = await api.get<{
      _id: string;
      name: string;
      locationId?: { _id: string; name: string } | string;
    }>(`/api/stores/${storeId}`);
    storeName = store.name;
    if (store.locationId && typeof store.locationId === 'object') {
      storeLocation = store.locationId.name;
    }

    // For store managers with multiple stores, fetch assigned stores for the switcher
    const storeIds = payload?.storeIds ?? [];
    if (storeIds.length > 1) {
      const allStores = await api.get<{ _id: string; name: string; locationId?: { _id: string; name: string } | string }[]>('/api/stores');
      assignedStores = allStores
        .filter((s) => storeIds.includes(s._id))
        .map((s) => ({
          _id: s._id,
          name: s.name,
          locationName: s.locationId && typeof s.locationId === 'object' ? s.locationId.name : undefined,
        }));
    }
  } catch {
    // Store may not be found; sidebar will still render without the name.
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - Agora POS</title>
  </head>
  <body class="bg-background text-foreground antialiased">
    <Toaster client:load />
    <div class="app-shell-bg flex h-screen overflow-hidden p-3 sm:p-4">
      <Sidebar
        role={userRole}
        currentPath={currentPath}
        storeId={storeId}
        storeName={storeName}
        storeLocation={storeLocation}
        assignedStores={assignedStores}
        client:load
      />
      <div class="app-surface ml-3 flex flex-1 flex-col overflow-hidden rounded-2xl">
        <Topbar name={userName} role={userRole} avatar={userAvatar} client:load />
        <main class="flex-1 overflow-y-auto p-4 sm:p-6">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
