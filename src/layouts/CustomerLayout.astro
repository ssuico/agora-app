---
import { Topbar } from '../components/app/Topbar';
import { Toaster } from '../components/app/Toaster';
import { decodeJWT } from '../lib/jwt';
import { createApiClient } from '../lib/api';
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Agora POS' } = Astro.props;

const token = Astro.cookies.get('agora_token')?.value ?? '';
const payload = decodeJWT(token);
let userName = payload?.name ?? 'User';
let userRole = payload?.role ?? 'customer';
let userAvatar: string | undefined;
try {
  const api = createApiClient(token);
  const me = await api.get<{ name?: string; role?: string; avatar?: string }>('/api/auth/me');
  if (me?.name) userName = me.name;
  if (me?.role) userRole = me.role;
  if (me?.avatar != null) userAvatar = typeof me.avatar === 'string' ? me.avatar : undefined;
} catch {
  // Use JWT payload only
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Agora POS</title>
  </head>
  <body class="bg-background text-foreground antialiased">
    <Toaster client:load />
    <div class="flex min-h-screen flex-col">
      <Topbar name={userName} role={userRole} avatar={userAvatar} client:load />
      <main class="flex-1 p-6">
        <slot />
      </main>
    </div>
  </body>
</html>
