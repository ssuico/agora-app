---
import CustomerLayout from '../layouts/CustomerLayout.astro';
import { PurchasesTable } from '../components/app/PurchasesTable';
import { createApiClient } from '../lib/api';

const token = Astro.cookies.get('agora_token')?.value ?? '';
const api = createApiClient(token);

interface TransactionItem {
  productName: string;
  quantity: number;
  subtotal: number;
  sellingPrice: number;
}

interface Transaction {
  _id: string;
  storeId: { _id: string; name: string } | string;
  totalAmount: number;
  createdAt: string;
  items: TransactionItem[];
}

let purchases: Transaction[] = [];
try {
  purchases = await api.get<Transaction[]>('/api/transactions/my-purchases');
} catch {
  // handled below
}
---

<CustomerLayout title="My Purchases">
  <div class="mx-auto max-w-3xl space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">My Purchases</h1>
        <p class="text-sm text-muted-foreground">Your purchase history</p>
      </div>
    </div>

    <PurchasesTable client:load purchases={purchases} />
  </div>
</CustomerLayout>
