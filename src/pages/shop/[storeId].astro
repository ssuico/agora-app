---
import { ShopView } from '../../components/app/ShopView';
import CustomerLayout from '../../layouts/CustomerLayout.astro';
import { createApiClient } from '../../lib/api';

const { storeId } = Astro.params;
const token = Astro.cookies.get('agora_token')?.value ?? '';
const api = createApiClient(token);

interface Store {
  _id: string;
  name: string;
  isOpen: boolean;
}

let storeName = 'Store';
let storeIsOpen = true;
try {
  const store = await api.get<Store>(`/api/stores/${storeId}`);
  storeName = store.name;
  storeIsOpen = store.isOpen ?? true;
} catch {
  // handled in component
}
---

<CustomerLayout title={storeName}>
  <ShopView storeId={storeId!} storeName={storeName} initialIsOpen={storeIsOpen} client:load />
</CustomerLayout>
