---
import { decodeJWT } from '../lib/jwt';

const token = Astro.cookies.get('agora_token')?.value ?? '';
const payload = decodeJWT(token);

if (!payload) {
  return Astro.redirect('/login');
}

switch (payload.role) {
  case 'admin':
    return Astro.redirect('/admin/dashboard');
  case 'store_manager': {
    const storeIds = payload.storeIds ?? [];
    if (storeIds.length === 1) {
      return Astro.redirect(`/store/${storeIds[0]}`);
    }
    return Astro.redirect('/store/select');
  }
  case 'customer':
    return Astro.redirect('/select-location');
  default:
    return Astro.redirect('/login');
}
---
