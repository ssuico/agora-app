---
import AppLayout from '../../layouts/AppLayout.astro';
import { createApiClient } from '../../lib/api';

const token = Astro.cookies.get('agora_token')?.value ?? '';
const api = createApiClient(token);

interface Location {
  _id: string;
  name: string;
}
interface Store {
  _id: string;
  name: string;
}
interface User {
  _id: string;
  name: string;
  role: string;
}
interface Summary {
  totalSales: number;
  grossProfit: number;
  netProfit: number;
  totalExpenses: number;
  totalCOGS: number;
  remainingCapital: number;
  transactionCount: number;
}

let locations: Location[] = [];
let stores: Store[] = [];
let users: User[] = [];
let summary: Summary = {
  totalSales: 0,
  grossProfit: 0,
  netProfit: 0,
  totalExpenses: 0,
  totalCOGS: 0,
  remainingCapital: 0,
  transactionCount: 0,
};
let perStoreSummaries: Array<{ store: Store; summary: Summary }> = [];

try {
  [locations, stores, users, summary] = await Promise.all([
    api.get<Location[]>('/api/locations'),
    api.get<Store[]>('/api/stores'),
    api.get<User[]>('/api/users'),
    api.get<Summary>('/api/reports/summary'),
  ]);
} catch {
  // Data may be unavailable on first load
}

const toSafeNumber = (value: unknown): number => {
  const n = typeof value === 'number' ? value : Number(value);
  return Number.isFinite(n) ? n : 0;
};

const normalizeSummary = (raw: Partial<Summary> | undefined): Summary => {
  const totalSales = toSafeNumber(raw?.totalSales);
  const grossProfit = toSafeNumber(raw?.grossProfit);
  const totalExpenses = toSafeNumber(raw?.totalExpenses);
  const totalCOGS = toSafeNumber(raw?.totalCOGS);
  const transactionCount = Math.round(toSafeNumber(raw?.transactionCount));
  const netProfitRaw = raw?.netProfit;
  const netProfit = Number.isFinite(Number(netProfitRaw))
    ? toSafeNumber(netProfitRaw)
    : grossProfit - totalExpenses;

  return {
    totalSales,
    grossProfit,
    netProfit,
    totalExpenses,
    totalCOGS,
    remainingCapital: toSafeNumber(raw?.remainingCapital),
    transactionCount,
  };
};

summary = normalizeSummary(summary);

if (stores.length > 0) {
  perStoreSummaries = await Promise.all(
    stores.map(async (store) => {
      try {
        const storeSummary = await api.get<Partial<Summary>>(
          `/api/reports/summary?storeId=${store._id}`
        );
        return { store, summary: normalizeSummary(storeSummary) };
      } catch {
        return { store, summary: normalizeSummary(undefined) };
      }
    })
  );
}

const fmt = (n: number) =>
  new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(toSafeNumber(n));

const managerCount = users.filter((u) => u.role === 'store_manager').length;
const customerCount = users.filter((u) => u.role === 'customer').length;

const overviewCards = [
  { label: 'Locations', value: locations.length.toString() },
  { label: 'Stores', value: stores.length.toString() },
  { label: 'Store Managers', value: managerCount.toString() },
  { label: 'Customers', value: customerCount.toString() },
];

const financeCards = [
  { label: 'Total Sales', value: fmt(summary.totalSales) },
  { label: 'Gross Profit', value: fmt(summary.grossProfit) },
  { label: 'Total Expenses', value: fmt(summary.totalExpenses) },
  { label: 'Net Profit', value: fmt(summary.netProfit) },
  { label: 'Transactions', value: summary.transactionCount.toString() },
];
---

<AppLayout title="Admin Dashboard">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Admin Dashboard</h1>
      <p class="text-sm text-muted-foreground">System-wide overview</p>
    </div>

    <div>
      <h2 class="mb-3 text-lg font-semibold">Overview</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          overviewCards.map((card) => (
            <div class="rounded-lg border bg-card p-5 shadow-sm">
              <p class="text-sm font-medium text-muted-foreground">{card.label}</p>
              <p class="mt-1 text-2xl font-bold">{card.value}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div>
      <h2 class="mb-3 text-lg font-semibold">Financial Summary (All Stores)</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          financeCards.map((card) => (
            <div class="rounded-lg border bg-card p-5 shadow-sm">
              <p class="text-sm font-medium text-muted-foreground">{card.label}</p>
              <p class="mt-1 text-2xl font-bold">{card.value}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div>
      <h2 class="mb-3 text-lg font-semibold">Financial Summary Per Store</h2>
      {
        perStoreSummaries.length === 0 ? (
          <div class="rounded-lg border bg-card p-5 text-sm text-muted-foreground">
            No stores found.
          </div>
        ) : (
          <div class="grid gap-4 lg:grid-cols-2">
            {perStoreSummaries.map(({ store, summary: storeSummary }) => (
              <div class="rounded-lg border bg-card p-5 shadow-sm">
                <h3 class="text-base font-semibold">{store.name}</h3>
                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                  <div>
                    <p class="text-xs text-muted-foreground">Total Sales</p>
                    <p class="text-lg font-bold">{fmt(storeSummary.totalSales)}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Gross Profit</p>
                    <p class="text-lg font-bold">{fmt(storeSummary.grossProfit)}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Total Expenses</p>
                    <p class="text-lg font-bold">{fmt(storeSummary.totalExpenses)}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Net Profit</p>
                    <p class="text-lg font-bold">{fmt(storeSummary.netProfit)}</p>
                  </div>
                  <div>
                    <p class="text-xs text-muted-foreground">Transactions</p>
                    <p class="text-lg font-bold">{storeSummary.transactionCount}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
</AppLayout>
