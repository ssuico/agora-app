---
import AuthLayout from '../layouts/AuthLayout.astro';
import { LoginForm } from '../components/app/LoginForm';
import { decodeJWT } from '../lib/jwt';

let sessionExpired = false;
const token = Astro.cookies.get('agora_token')?.value;
if (token) {
  const payload = decodeJWT(token);
  // Only redirect if token is valid; otherwise clear stale cookie to avoid redirect loop
  if (payload) {
    const isExpired = payload.exp != null && payload.exp * 1000 < Date.now();
    if (!isExpired) return Astro.redirect('/');
  }
  Astro.cookies.delete('agora_token', { path: '/' });
  sessionExpired = true;
}
---

<AuthLayout title="Sign in">
  <div class="relative z-10 w-full max-w-5xl overflow-hidden rounded-[2rem] border border-white/40 bg-white/45 shadow-[0_30px_80px_-35px_rgba(15,54,21,0.6)] backdrop-blur-xl">
    <div class="grid min-h-[560px] lg:grid-cols-[1.08fr_0.92fr]">
      <section class="relative hidden overflow-hidden bg-[linear-gradient(140deg,rgba(39,102,54,0.95),rgba(97,156,99,0.9))] p-10 text-emerald-50 lg:flex lg:flex-col lg:justify-between">
        <div class="space-y-4">
          <p class="inline-flex rounded-full border border-white/25 bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-50/90">
            Unified Access Portal
          </p>
          <h1 class="max-w-sm text-4xl font-semibold leading-tight">
            One account hub for customers and store teams.
          </h1>
          <p class="max-w-sm text-sm leading-6 text-emerald-50/85">
            Browse and purchase as a customer, or manage operations as a store user with the same secure sign-in.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-3 text-sm">
          <div class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3">
            <p class="text-xl font-semibold">2 User Types</p>
            <p class="text-emerald-100/90">Customers and Staff</p>
            <p class="mt-1 text-xs text-emerald-100/70">Single entry point, role-based experience after login.</p>
          </div>
          <div class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3">
            <p class="text-xl font-semibold">By Store</p>
            <p class="text-emerald-100/90">Opening Hours</p>
            <p class="mt-1 text-xs text-emerald-100/70">Access and activity align with each branch schedule.</p>
          </div>
          <div class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3">
            <p class="text-xl font-semibold">Secure</p>
            <p class="text-emerald-100/90">Role-Based Routing</p>
            <p class="mt-1 text-xs text-emerald-100/70">Users land only on the pages that match their account.</p>
          </div>
        </div>
      </section>
      <section class="flex items-center justify-center p-5 sm:p-8 lg:p-10">
        <div class="w-full max-w-md space-y-4">
          {sessionExpired && (
            <div
              role="alert"
              class="w-full rounded-lg border border-amber-500/55 bg-amber-500/10 px-4 py-3 text-sm text-amber-800"
            >
              Your session has expired. Please sign in again.
            </div>
          )}
          <LoginForm client:load />
          <div class="flex justify-center pt-3">
            <p class="inline-flex items-center rounded-full border border-emerald-800/30 bg-white/90 px-4 py-1.5 text-xs font-semibold tracking-[0.08em] text-emerald-900 shadow-[0_12px_26px_-16px_rgba(17,78,42,0.85)]">
              Powered by Channel Precision Devs
            </p>
          </div>
        </div>
      </section>
    </div>
  </div>
</AuthLayout>
