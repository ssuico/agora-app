{
  "name": "agora-app",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:server": "cd server && pnpm dev",
    "dev:all": "concurrently -n \"server,astro\" -c \"blue,green\" \"cd server && pnpm dev\" \"astro dev\"",
    "dev:all:host": "concurrently -n \"server,astro\" -c \"blue,green\" \"cd server && pnpm dev\" \"astro dev --host\"",
    "clean:cache": "node -e \"const fs=require('fs');const p=(d)=>fs.existsSync(d)&&fs.rmSync(d,{recursive:true,force:true});p('node_modules/.vite');p('node_modules/.astro');console.log('Vite/Astro cache cleared.');\"",
    "build": "astro build && cd server && pnpm install --frozen-lockfile && pnpm build",
    "start": "node server/dist/index.js",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/node": "^9.5.4",
    "@astrojs/react": "^4.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.17.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0"
  }
}