# === Development (Astro dev server + separate Express server) ===
# Used by Astro proxy routes to forward API calls to Express
PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# === Production (single Express server serves everything) ===
# These are not needed in production since Express handles API directly.
# On Railway, just set environment variables in the server/.env section.
